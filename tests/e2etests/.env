TEST_URL=https://tine.local.tine-dev.de
TEST_USERNAME=tine20admin
TEST_PASSWORD=tine20admin
SETUP_USERNAME=tine20setup
SETUP_PASSWORD=tine20setup
HTACCESS_USERNAME=dev
HTACCESS_PASSWORD=dev
TEST_MODE=headless
#TEST_MODE=debug
TEST_BRANDING_TITLE='tine ®'
TEST_WORKER=1
TEST_DIR=src
TEST_BROWSER_LANGUAGE=de
TEST_USER=tine ® Admin
MFA=0
LOGLEVEL=6
TEST_ALL_SCREENSHOT=true
TEST_RESOLUTION='{"width": 1920, "height": 1020}'
# Define separate timeouts for different cases, in milliseconds. Set to 0 to disable timeouts.
# Set these values according to the expected load times of your application and the performance of your testing environment.
# Waiting for the browser to launch and navigate to the initial URL.
TEST_TIMEOUT_BROWSER=10000
# Waiting for the page to load and become interactive (includes DOM ready, all resources loaded, any initial JS execution completed).
TEST_TIMEOUT_CONTENT_READY=20000
# Waiting for a popup to open.
TEST_TIMEOUT_POPUP_OPEN=5000
# Waiting for a popup to close.
TEST_TIMEOUT_POPUP_CLOSE=5000
# Waiting for an actionable element to become available (e.g., a button clickable).
TEST_TIMEOUT_ACTIONABLE=5000
# Waiting for a loading indicator to disappear.
TEST_TIMEOUT_MASK=20000
# Waiting for a form value to change after filling (tiny autocomplete delay possible).
TEST_TIMEOUT_FORM_VALUE_CHANGED=1000
# Waiting for a network request to complete (TIMEOUT), and time to pass without any further network traffic (IDLE).
TEST_TIMEOUT_NETWORK_TIMEOUT=5000
TEST_TIMEOUT_NETWORK_IDLE=500
# Waiting for a grid/table/list to update after reload.
TEST_TIMEOUT_GRID_UPDATED=10000
 # Network throttling for base page and popup separately, 10 Mbit/s download and upload speed, 20 ms latency.
#TEST_NETWORK_CONDITIONS_MAIN='{"offline": false, "downloadThroughput": 10485760, "uploadThroughput": 10485760, "latency": 20}'
#TEST_NETWORK_CONDITIONS_POPUP='{"offline": false, "downloadThroughput": 10485760, "uploadThroughput": 10485760, "latency": 20}'
# CPU throttling for base page and popup separately, 4x slowdown.
#TEST_CPU_THROTTLING_RATE_MAIN=4
#TEST_CPU_THROTTLING_RATE_POPUP=4
# activate this in debug mode if your browser language is en
#TEST_BROWSER_LANGUAGE=en
# activate this to prevent browser sandbox mode (--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage)
# TEST_DOCKER=true
