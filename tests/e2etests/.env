TEST_URL=https://tine.local.tine-dev.de/
TEST_USERNAME=tine20admin
TEST_PASSWORD=tine20admin
SETUP_USERNAME=tine20setup
SETUP_PASSWORD=tine20setup
HTACCESS_USERNAME=dev
HTACCESS_PASSWORD=dev
TEST_MODE=headless
#TEST_MODE=debug
TEST_BRANDING_TITLE='tine ®'
TEST_WORKER=1
TEST_DIR=src
TEST_BROWSER_LANGUAGE=de
TEST_USER=tine ® Admin
MFA=0
LOGLEVEL=6
TEST_ALL_SCREENSHOT=true
TEST_RESOLUTION='{"width": 1920, "height": 1020}'
# Separate timeouts for different test steps, in milliseconds. Set to 0 to disable timeouts.
TEST_TIMEOUT_BROWSER=30000
TEST_TIMEOUT_CONTENT_READY=10000
TEST_TIMEOUT_POPUP=10000
TEST_TIMEOUT_ACTIONABLE=7000
TEST_TIMEOUT_MASK=10000
 # Network throttling for base page and popup separately, 10 Mbit/s download and upload speed, 20 ms latency.
#TEST_NETWORK_CONDITIONS_MAIN='{"offline": false, "downloadThroughput": 10485760, "uploadThroughput": 10485760, "latency": 20}'
#TEST_NETWORK_CONDITIONS_POPUP='{"offline": false, "downloadThroughput": 10485760, "uploadThroughput": 10485760, "latency": 20}'
# CPU throttling for base page and popup separately, 4x slowdown.
#TEST_CPU_THROTTLING_RATE_MAIN=4
#TEST_CPU_THROTTLING_RATE_POPUP=4

# activate this in debug mode if your browser language is en
#TEST_BROWSER_LANGUAGE=en
# activate this to prevent browser sandbox mode (--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage)
# TEST_DOCKER=true
